# Конфигурация приложения (без секретов).
# Скопировать в .cont_one_app.env и при необходимости отредактировать.
# PUBLIC_BASE_URL и CORS_ORIGIN формируются в backend из APP_HOST, ENABLE_HTTPS и портов — задавать не нужно.
# Секреты — в .cont_one_app.secrets.env.
#
# Локально с HTTPS (рекомендуемый режим): ENABLE_HTTPS=true, порты как ниже.
# Сертификаты ./certs/kanban.crt и kanban.key создаст ./run_one_app_dev.sh при первом запуске.
# В браузере открывайте https://localhost:8443 (или ваш APP_HOST и FRONTEND_HTTPS_PORT).

APP_HOST=localhost
ENABLE_HTTPS=true
FRONTEND_HTTP_PORT=8080
FRONTEND_HTTPS_PORT=8443
CERTS_PATH=./certs

POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban
POSTGRES_DB=kanban
DATABASE_URL=postgresql://kanban:kanban@db:5432/kanban?schema=public
BACKEND_PORT=4000

# Прокси для docker build (только с ./run_one_app_dev.sh --proxy). Логин/пароль — PROXY_USER/PROXY_PASSWORD в .cont_one_app.secrets.env.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,db,127.0.0.0/8
